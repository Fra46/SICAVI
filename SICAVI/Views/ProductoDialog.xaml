<ContentDialog
    x:Class="SICAVI.WinUI.Views.ProductoDialog"
    x:Name="CodigoTextBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:SICAVI.WinUI.Converters"
    Title="Nuevo Producto"
    PrimaryButtonText="Guardar"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    CloseButtonText="Cancelar">

    <ContentDialog.Resources>
        <conv:DecimalConverter x:Key="DecimalConverter"/>
    </ContentDialog.Resources>

    <StackPanel Spacing="10">

        <InfoBar
        x:Name="ErrorBar"
        Severity="Error"
        IsOpen="False"/>

        <TextBox Header="Código" Text="{Binding Codigo, Mode=TwoWay}"/>
        <TextBox Header="Nombre" Text="{Binding Nombre, Mode=TwoWay}" PlaceholderText="Ej: Martillo"/>
        <TextBox Header="Precio" Text="{Binding Precio, Mode=TwoWay, Converter={StaticResource DecimalConverter}}" PlaceholderText="Ej: 25000"/>
        <TextBox Header="Stock" Text="{Binding Stock, Mode=TwoWay}" PlaceholderText="Ej: 10"/>

    </StackPanel>
</ContentDialog>