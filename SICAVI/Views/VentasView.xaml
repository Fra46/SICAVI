<Page
    x:Class="SICAVI.Views.VentasView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SICAVI.WinUI.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <Page.DataContext>
        <vm:VentasViewModel/>
    </Page.DataContext>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Métricas -->
            <RowDefinition Height="Auto"/>
            <!-- Botones -->
            <RowDefinition Height="Auto"/>
            <!-- Error -->
            <RowDefinition Height="*"/>
            <!-- Tabla -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Ventas"
                       FontSize="28"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Registro e historial de ventas"
                       Opacity="0.6"/>
        </StackPanel>

        <!-- ══ MÉTRICAS RÁPIDAS ══ -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Card: ventas hoy -->
            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10"
                    Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Ventas hoy"
                               FontSize="12"
                               Opacity="0.6"/>
                    <TextBlock Text="{Binding CantidadVentasHoy}"
                               FontSize="28"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Card: total hoy -->
            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10"
                    Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Total hoy"
                               FontSize="12"
                               Opacity="0.6"/>
                    <TextBlock Text="{Binding TotalVentasHoyDisplay}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Placeholder info -->
            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10"
                    Padding="16,12">
                <TextBlock Text="💡 Doble clic en una fila para ver el detalle completo de la venta."
                           Opacity="0.5"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- ══ BOTONES DE ACCIÓN ══ -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="10">
            <Button Content="➕  Nueva venta"
                    Click="NuevaVenta_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="14,7"/>
            <Button Content="🗑  Anular venta"
                    Command="{Binding AnularVentaCommand}"
                    Padding="14,7"/>
            <Button Content="🔄  Actualizar"
                    Command="{Binding ActualizarCommand}"
                    Padding="14,7"/>
        </StackPanel>

        <!-- ══ ERROR BAR ══ -->
        <InfoBar Grid.Row="3"
                 x:Name="GlobalErrorBar"
                 Severity="Error"
                 IsOpen="{Binding HayError}"
                 Message="{Binding MensajeError}"
                 IsClosable="True"/>

        <!-- ══ HISTORIAL (DataGrid) ══ -->
        <Border Grid.Row="4"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12"
                Padding="12">
            <controls:DataGrid
                ItemsSource="{Binding Ventas}"
                SelectedItem="{Binding VentaSeleccionada, Mode=TwoWay}"
                AutoGenerateColumns="False"
                CanUserSortColumns="True"
                GridLinesVisibility="Horizontal"
                DoubleTapped="VerDetalleVenta_DoubleTapped">

                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Fecha"
                                                 Binding="{Binding FechaDisplay}"
                                                 Width="130"/>
                    <controls:DataGridTextColumn Header="Cliente"
                                                 Binding="{Binding ClienteDisplay}"
                                                 Width="*"/>
                    <controls:DataGridTextColumn Header="Empleado"
                                                 Binding="{Binding EmpleadoDisplay}"
                                                 Width="*"/>
                    <controls:DataGridTextColumn Header="Metodo pago"
                                                 Binding="{Binding MetodoPago}"
                                                 Width="130"/>
                    <controls:DataGridTextColumn Header="Total"
                                                 Binding="{Binding TotalDisplay}"
                                                 Width="110"/>
                    <controls:DataGridTextColumn Header="Estado"
                                                 Binding="{Binding EstadoDisplay}"
                                                 Width="90"/>
                </controls:DataGrid.Columns>

            </controls:DataGrid>
        </Border>
    </Grid>
</Page>
