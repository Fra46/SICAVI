<ContentDialog
    x:Class="SICAVI.WinUI.Views.NuevaCotizacionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:SICAVI.WinUI.Converters"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Title="Nueva Cotización"
    PrimaryButtonText="Guardar cotización"
    PrimaryButtonClick="OnGuardar_Click"
    CloseButtonText="Cancelar"
    DefaultButton="Primary"
    MinWidth="680">

    <ContentDialog.Resources>
        <conv:DecimalConverter x:Key="DecimalConverter"/>
    </ContentDialog.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560">
        <StackPanel Spacing="16" Padding="4,8">

            <InfoBar x:Name="ErrorBar" Severity="Error" IsOpen="False"/>

            <!-- Cliente + Vencimiento -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Cliente" FontWeight="SemiBold" FontSize="13"/>
                    <ComboBox x:Name="ClienteCombo"
                              ItemsSource="{x:Bind Clientes}"
                              PlaceholderText="Sin cliente (opcional)"
                              DisplayMemberPath="NombreCompleto"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Válida hasta (días)" FontWeight="SemiBold" FontSize="13"/>
                    <NumberBox x:Name="DiasVencimiento"
                               Minimum="1" Maximum="365" Value="15"
                               SpinButtonPlacementMode="Compact"
                               HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.4"/>

            <!-- Carrito -->
            <TextBlock Text="Productos" FontWeight="SemiBold" FontSize="14"/>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ProductoCombo" Grid.Column="0"
                          ItemsSource="{x:Bind Productos}"
                          DisplayMemberPath="NombreCompleto"
                          PlaceholderText="Seleccionar producto..."
                          HorizontalAlignment="Stretch"/>
                <NumberBox x:Name="CantidadBox" Grid.Column="1"
                           Minimum="1" Value="1" SpinButtonPlacementMode="Compact"/>
                <Button Grid.Column="2" Content="Agregar"
                        Click="AgregarAlCarrito_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        VerticalAlignment="Bottom" Padding="16,8"/>
            </Grid>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="8" MinHeight="120">
                <controls:DataGrid x:Name="CarritoGrid"
                                   ItemsSource="{x:Bind Detalles}"
                                   AutoGenerateColumns="False"
                                   CanUserSortColumns="False"
                                   GridLinesVisibility="Horizontal">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Producto"    Binding="{Binding ProductoDisplay}" Width="*"/>
                        <controls:DataGridTextColumn Header="Precio unit." Binding="{Binding PrecioDisplay}"  Width="110"/>
                        <controls:DataGridTextColumn Header="Cant."        Binding="{Binding Cantidad}"       Width="70"/>
                        <controls:DataGridTextColumn Header="Subtotal"    Binding="{Binding SubtotalDisplay}" Width="110"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </Border>

            <Button Content="🗑  Quitar seleccionado" Click="QuitarDetalle_Click" Padding="12,6"/>

            <!-- Observaciones -->
            <TextBox x:Name="ObsBox" Header="Observaciones (opcional)"
                     PlaceholderText="Ej: Incluye instalación"/>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Opacity="0.4"/>

            <!-- Totales -->
            <Grid HorizontalAlignment="Right" Width="260" RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Subtotal" Opacity="0.7"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SubtotalText" Text="$0" HorizontalAlignment="Right"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="IVA (19%)" Opacity="0.7"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="IvaText" Text="$0" HorizontalAlignment="Right"/>
                <Border Grid.Row="2" Grid.ColumnSpan="2" Height="1" Margin="0,4"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="TOTAL" FontWeight="Bold" FontSize="16"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TotalText" Text="$0"
                           FontWeight="Bold" FontSize="16" HorizontalAlignment="Right"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
