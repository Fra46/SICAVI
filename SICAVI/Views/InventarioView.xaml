<Page
    x:Class="SICAVI.WinUI.Views.InventarioView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SICAVI.WinUI.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <Page.DataContext>
        <vm:InventarioViewModel/>
    </Page.DataContext>

    <Grid Padding="24"
      RowSpacing="16">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Botones -->
            <RowDefinition Height="*"/>
            <!-- Tabla -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Inventario"
                   FontSize="28"
                   FontWeight="SemiBold"/>
            <TextBlock Text="Gestiona los productos de la tienda"
                   Opacity="0.7"/>
        </StackPanel>

        <!-- Botones -->
        <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                Spacing="12">
            <Button Content="➕ Agregar"
                Click="AgregarProducto_Click"
                Padding="12,6"/>
            <Button Content="🗑 Eliminar"
                Command="{Binding EliminarProductoCommand}"
                Padding="12,6"/>
        </StackPanel>

        <!-- Tabla -->
        <Border Grid.Row="2"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="12"
            Padding="12">
            <controls:DataGrid ItemsSource="{Binding Productos}"
                           SelectedItem="{Binding ProductoSeleccionado, Mode=TwoWay}"
                           AutoGenerateColumns="False"
                           DoubleTapped="EditarProducto_DoubleTapped">

                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Código"
                                             Binding="{Binding Codigo, Mode=TwoWay}"/>
                    <controls:DataGridTextColumn Header="Nombre"
                                             Binding="{Binding Nombre, Mode=TwoWay}"/>
                    <controls:DataGridTextColumn Header="Precio"
                                             Binding="{Binding Precio, Mode=TwoWay}"/>
                    <controls:DataGridTextColumn Header="Stock"
                                             Binding="{Binding Stock, Mode=TwoWay}"/>
                </controls:DataGrid.Columns>

            </controls:DataGrid>
        </Border>
    </Grid>
</Page>